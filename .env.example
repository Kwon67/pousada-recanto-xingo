# ===========================
# APP / SITE
# ===========================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# ===========================
# SUPABASE
# ===========================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Use pelo menos uma das chaves abaixo no servidor:
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
SUPABASE_SERVICE_ROLE_KEY=

# ===========================
# ADMIN
# ===========================
ADMIN_USERNAME=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_DELETE_PASSWORD=CHANGE_ME_DIFFERENT_FROM_LOGIN_PASSWORD
ADMIN_ALLOWED_ORIGINS=http://localhost:3000
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_SECONDS=900
ADMIN_NOTIFICATION_EMAIL=admin@example.com
# NUNCA habilite em produção:
ADMIN_ALLOW_INSECURE_DEV_DEFAULTS=false

# ===========================
# RESERVA / RATE LIMIT
# ===========================
# OBRIGATÓRIO em produção — deve ser diferente de ADMIN_SESSION_SECRET
RESERVA_PUBLIC_TOKEN_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
RESERVA_PUBLIC_TOKEN_TTL_SECONDS=2592000
RESERVA_RATE_LIMIT_WINDOW_SECONDS=900
RESERVA_RATE_LIMIT_MAX_ATTEMPTS_IP=20
RESERVA_RATE_LIMIT_MAX_ATTEMPTS_EMAIL=8
# Número de proxies confiáveis na frente da aplicação (ex: Vercel = 1)
TRUSTED_PROXY_COUNT=1

# ===========================
# ABACATE PAY
# ===========================
ABACATEPAY_API_KEY=CHANGE_ME
ABACATEPAY_WEBHOOK_SECRET=CHANGE_ME
# Opcional: chave pública para validação HMAC do webhook
ABACATEPAY_WEBHOOK_PUBLIC_KEY=

# ===========================
# CLOUDINARY
# ===========================
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# ===========================
# RESEND (EMAIL)
# ===========================
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=Pousada Recanto do Matuto <reservas@example.com>

# ===========================
# META / PIXEL (opcional)
# ===========================
NEXT_PUBLIC_META_PIXEL_ID=
META_ACCESS_TOKEN=
